generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id             String    @id // UUID v7 generated in application
  userId         String?   @map("user_id")
  email          String?
  startedAt      DateTime  @map("started_at")
  endedAt        DateTime? @map("ended_at")
  metadata       Json?     @db.JsonB
  source         String?   @default("web")
  events         SessionEvent[]
  paymentFailures PaymentFailure[]
  coupons        Coupon[]

  @@map("sessions")
}

model SessionEvent {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType  String   @map("event_type")
  payload    Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("session_events")
}

model PaymentFailure {
  id          String    @id @default(uuid())
  sessionId   String?   @map("session_id")
  session     Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  externalId  String?   @map("external_id")
  amount      Decimal?  @db.Decimal(12, 2)
  reason      String?
  payload     Json?     @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  @@map("payment_failures")
}

model Coupon {
  id                 String    @id @default(uuid())
  sessionId          String    @map("session_id")
  session            Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userEmail          String    @map("user_email")
  code               String
  discountType       String    @map("discount_type")
  discountValue      String    @map("discount_value")
  personalizedMessage String?  @map("personalized_message")
  priority           String
  sentAt             DateTime? @map("sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@map("coupons")
}
